# Main database connection: point to Saraburi because competency tables and Emp are here
DB_SERVER=10.0.1.1
DB_PORT=1433
DB_DATABASE=Saraburi
DB_USER=your_user
DB_PASSWORD=your_password

# PYREXT and GetUserFullName are in this database
SSB_DATABASE=SSBDatabase

# SQL Server options
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_POOL_MAX=10
DB_REQUEST_TIMEOUT=30000

# Change this before real use. Any long random text is fine.
SESSION_SECRET=change-this-to-a-long-random-secret
